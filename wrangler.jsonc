{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "blogs",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-07-13",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "routes": [
    {
      "pattern": "blogs.aniketdhakane.xyz",
      "custom_domain": true
    }
  ],
  "observability": {
    "enabled": true
  }
}
